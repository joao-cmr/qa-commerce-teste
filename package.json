{
  "name": "qa-commerce-teste",
  "version": "1.0.0",
  "description": "Automação completa de testes: E2E (Cypress), API (Postman/Newman e Supertest) e Performance (K6)",
  "main": "index.js",
  "scripts": {
    "start": "http-server -p 3000",
    
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "cy:run:chrome": "cypress run --browser chrome",
    "cy:run:headed": "cypress run --headed",
    
    "report:clean": "rimraf cypress/reports",
    "report:merge": "mochawesome-merge cypress/reports/*.json > cypress/reports/report.json",
    "report:generate": "marge cypress/reports/report.json --reportDir cypress/reports --inline",
    "report:cy": "npm run report:clean && cypress run && npm run report:merge && npm run report:generate",
    
    "test:api:newman": "newman run API/postman/collections/login.postman_collection.json -e API/postman/environments/qa-commerce.postman_environment.json --reporters cli,htmlextra --reporter-htmlextra-export reports/api/newman-login.html",
    
    "test:api:supertest": "jest --config API/supertest/jest.config.js --coverage",
    "test:api:supertest:watch": "jest --watch --config API/supertest/jest.config.js",
    
    "test:perf:load": "k6 run performance/scripts/load-test.js",
    "test:perf:stress": "k6 run performance/scripts/stress-test.js",
    
    "test:all:e2e": "npm run cy:run",
    "test:all:api": "npm run test:api:newman && npm run test:api:supertest",
    "test:all": "npm run test:all:e2e && npm run test:all:api"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joao-cmr/qa-commerce-teste.git"
  },
  "keywords": [
    "qa",
    "automation",
    "cypress",
    "newman",
    "supertest",
    "k6",
    "e2e",
    "api-testing",
    "performance-testing"
  ],
  "author": "João Carlos",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/joao-cmr/qa-commerce-teste/issues"
  },
  "homepage": "https://github.com/joao-cmr/qa-commerce-teste#readme",
  "devDependencies": {
    "@faker-js/faker": "^10.3.0",
    "cypress": "^14.3.2",
    "http-server": "^14.1.1",
    "jest": "^29.7.0",
    "mochawesome": "^7.1.4",
    "mochawesome-merge": "^4.4.1",
    "mochawesome-report-generator": "^6.3.2",
    "newman": "^6.2.1",
    "newman-reporter-htmlextra": "^1.23.1",
    "rimraf": "^6.1.3",
    "start-server-and-test": "^2.1.5",
    "supertest": "^7.0.0",
    "wait-on": "^7.2.0"
  }
}