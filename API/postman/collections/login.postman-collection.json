  "item": [
    {
      "name": "Criação de usuário com sucesso",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.environment.set(\"id_users\", pm.response.json().id)\r",
              "\r",
              "pm.test(\"Status code deve ser 201\", () => {\r",
              "    pm.response.to.have.status(201);\r",
              "});\r",
              "\r",
              "pm.test(\"Usuário criado com sucesso\", () => {\r",
              "pm.expect(pm.response.text()).to.include(\"Usuário criado com sucesso.\");\r",
              "\r",
              "})"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "accept",
            "value": "application/json"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\r\n  \"name\": \"João Carlos\",\r\n  \"email\": \"{{users}}\",\r\n  \"password\": \"{{password}}\",\r\n  \"isAdmin\": true\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}users",
          "host": [
            "{{baseUrl}}users"
          ]
        },
        "description": "Generated from cURL: curl -X 'POST' \\\r\n  'http://localhost:3000/api/users' \\\r\n  -H 'accept: application/json' \\\r\n  -H 'Content-Type: application/json' \\\r\n  -d '{\r\n  \"name\": \"John Doe\",\r\n  \"email\": \"john.doe@example.com\",\r\n  \"password\": \"Password123!\",\r\n  \"isAdmin\": false\r\n}'"
